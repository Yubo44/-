.page-shell {
  padding: 32rpx 24rpx 48rpx;
}

.hero-card,
.panel-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 251, 244, 0.78);
  box-shadow: 0 24rpx 60rpx rgba(49, 62, 52, 0.1);
  backdrop-filter: blur(18rpx);
  overflow: hidden;
}

.hero-card::before,
.panel-card::before {
  content: "";
  position: absolute;
  inset: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  border-radius: 32rpx;
  pointer-events: none;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.eyebrow {
  color: #986428;
  font-size: 22rpx;
  letter-spacing: 6rpx;
}

.hero-title {
  color: #10353b;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1.08;
}

.hero-text {
  color: rgba(16, 53, 59, 0.72);
  font-size: 28rpx;
  line-height: 1.7;
}

.stat-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat-card {
  flex: 1;
  padding: 22rpx 18rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(255, 248, 232, 0.95), rgba(241, 227, 198, 0.92));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.stat-value {
  display: block;
  color: #15393f;
  font-size: 40rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 6rpx;
  color: rgba(21, 57, 63, 0.7);
  font-size: 24rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  display: block;
  color: #10353b;
  font-size: 36rpx;
  font-weight: 700;
}

.panel-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(16, 53, 59, 0.62);
  font-size: 24rpx;
  line-height: 1.6;
}

.ghost-action,
.draft-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #12464d;
  font-size: 24rpx;
  background: rgba(19, 87, 95, 0.08);
}

.globe-scene {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 0 8rpx;
}

.globe-shadow {
  position: absolute;
  bottom: 56rpx;
  width: 420rpx;
  height: 84rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(6, 18, 21, 0.34) 0%, rgba(6, 18, 21, 0) 70%);
  filter: blur(18rpx);
}

.globe-shell {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  overflow: hidden;
  background:
    radial-gradient(circle at 28% 24%, rgba(105, 235, 255, 0.32), transparent 24%),
    radial-gradient(circle at 70% 75%, rgba(5, 17, 20, 0.44), transparent 48%),
    linear-gradient(160deg, #1d7b88 0%, #174e59 38%, #0d2830 100%);
  box-shadow:
    inset -48rpx -36rpx 90rpx rgba(0, 0, 0, 0.38),
    inset 18rpx 24rpx 48rpx rgba(255, 255, 255, 0.08),
    0 28rpx 54rpx rgba(12, 40, 44, 0.2);
  transform: scale(1);
  transition: transform 180ms ease;
}

.globe-shell.dragging {
  transform: scale(1.02);
}

.globe-ocean,
.globe-ring,
.globe-texture-track,
.globe-limb,
.globe-terminator,
.globe-highlight,
.globe-atmosphere {
  position: absolute;
}

.globe-ocean,
.globe-ring,
.globe-limb,
.globe-terminator,
.globe-highlight {
  inset: 0;
  border-radius: 50%;
}

.globe-ocean {
  background:
    radial-gradient(circle at 24% 18%, rgba(151, 244, 255, 0.26), transparent 26%),
    radial-gradient(circle at 55% 45%, rgba(13, 102, 117, 0.18), transparent 34%);
}

.globe-ring {
  inset: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.globe-texture-track {
  inset: 0;
  width: 200%;
  height: 100%;
  display: flex;
}

.globe-texture-panel {
  position: relative;
  flex: 0 0 50%;
  height: 100%;
  overflow: hidden;
}

.globe-texture-image {
  width: 100%;
  height: 100%;
  opacity: 0.76;
}

.globe-limb {
  background: radial-gradient(circle, rgba(255, 255, 255, 0) 55%, rgba(3, 13, 16, 0.16) 72%, rgba(3, 13, 16, 0.42) 100%);
}

.globe-terminator {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.12) 28%, rgba(255, 255, 255, 0.02) 48%, rgba(5, 15, 18, 0.24) 72%, rgba(5, 15, 18, 0.72) 100%);
}

.globe-highlight {
  background:
    radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.34), transparent 34%),
    radial-gradient(circle at 16% 48%, rgba(255, 255, 255, 0.12), transparent 22%);
  pointer-events: none;
}

.globe-atmosphere {
  inset: -10rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(154, 245, 255, 0.2);
  box-shadow: 0 0 30rpx rgba(83, 228, 247, 0.24);
  pointer-events: none;
}

.globe-pin {
  position: absolute;
}

.pin-core {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.72);
}

.globe-pin.visited .pin-core {
  background: #ffcf5c;
  box-shadow: 0 0 0 10rpx rgba(255, 207, 92, 0.16), 0 0 18rpx rgba(255, 207, 92, 0.9);
}

.globe-pin.planned .pin-core {
  background: #5de7f2;
  box-shadow: 0 0 0 10rpx rgba(93, 231, 242, 0.12), 0 0 14rpx rgba(93, 231, 242, 0.72);
}

.globe-pin.active .pin-core {
  transform: scale(1.18);
}

.pin-badge {
  position: absolute;
  left: 50%;
  bottom: 26rpx;
  transform: translateX(-50%);
  max-width: 220rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(8, 17, 18, 0.8);
  color: #fff8ea;
  font-size: 20rpx;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
}

.globe-pin.active .pin-badge {
  opacity: 1;
}

.globe-caption {
  margin-top: 26rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(17, 78, 85, 0.08);
  color: rgba(16, 53, 59, 0.72);
  font-size: 23rpx;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: rgba(16, 53, 59, 0.72);
  font-size: 24rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.visited {
  background: #f5bc37;
  box-shadow: 0 0 14rpx rgba(245, 188, 55, 0.7);
}

.legend-dot.planned {
  background: #43d8e9;
  box-shadow: 0 0 14rpx rgba(67, 216, 233, 0.6);
}

.field-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  color: #124046;
  font-size: 26rpx;
  font-weight: 600;
}

.field-hint {
  color: rgba(18, 64, 70, 0.56);
  font-size: 22rpx;
}

.city-input,
.memo-input {
  width: 100%;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.75);
  box-sizing: border-box;
  box-shadow: inset 0 0 0 1rpx rgba(18, 64, 70, 0.08);
}

.city-input {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #10353b;
}

.memo-input {
  min-height: 180rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #10353b;
}

.input-placeholder {
  color: rgba(16, 53, 59, 0.32);
}

.selection-tip {
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(17, 91, 99, 0.09);
  color: #15545c;
  font-size: 23rpx;
}

.selection-tip.muted {
  background: rgba(152, 100, 40, 0.08);
  color: rgba(90, 62, 37, 0.82);
}

.suggestion-list {
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(18, 64, 70, 0.08);
}

.suggestion-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(18, 64, 70, 0.06);
}

.suggestion-item:last-child {
  border-bottom: 0;
}

.suggestion-title {
  display: block;
  color: #10353b;
  font-size: 28rpx;
}

.suggestion-subtitle {
  display: block;
  margin-top: 6rpx;
  color: rgba(16, 53, 59, 0.52);
  font-size: 22rpx;
}

.suggestion-action {
  color: #8f5f25;
  font-size: 24rpx;
}

.status-toggle {
  display: flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(17, 78, 85, 0.08);
}

.status-option {
  flex: 1;
  padding: 18rpx 12rpx;
  text-align: center;
  color: rgba(16, 53, 59, 0.56);
  font-size: 26rpx;
  border-radius: 999rpx;
  transition: all 200ms ease;
}

.status-option.active {
  color: #fffaf0;
  background: linear-gradient(135deg, #0e535a, #1e7f86);
  box-shadow: 0 10rpx 24rpx rgba(14, 83, 90, 0.22);
}

.photo-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.photo-grid,
.record-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-card,
.record-photo-card,
.photo-add {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: 24rpx;
  overflow: hidden;
}

.photo-card,
.record-photo-card {
  background: rgba(255, 255, 255, 0.92);
}

.photo-image,
.record-photo {
  width: 100%;
  height: 100%;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background:
    linear-gradient(180deg, rgba(255, 248, 233, 0.95), rgba(237, 226, 201, 0.94));
  box-shadow: inset 0 0 0 1rpx rgba(18, 64, 70, 0.08);
}

.photo-add-mark {
  color: #12464d;
  font-size: 52rpx;
  line-height: 1;
}

.photo-add-text {
  color: rgba(18, 64, 70, 0.72);
  font-size: 22rpx;
}

.photo-delete {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.68);
  color: #fff;
  font-size: 22rpx;
  line-height: 42rpx;
  text-align: center;
}

.save-button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #124951, #2a8a92);
  color: #fff7eb;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 96rpx;
  box-shadow: 0 18rpx 30rpx rgba(18, 73, 81, 0.18);
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: rgba(16, 53, 59, 0.56);
  font-size: 24rpx;
  background: rgba(17, 78, 85, 0.08);
}

.filter-chip.active {
  color: #fff8eb;
  background: #0f5c64;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(18, 64, 70, 0.08);
}

.record-card.active {
  box-shadow:
    inset 0 0 0 2rpx rgba(44, 137, 147, 0.38),
    0 20rpx 40rpx rgba(18, 73, 81, 0.08);
}

.record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.record-title-wrap {
  flex: 1;
}

.record-title {
  display: block;
  color: #10353b;
  font-size: 30rpx;
  font-weight: 700;
}

.record-subtitle {
  display: block;
  margin-top: 6rpx;
  color: rgba(16, 53, 59, 0.56);
  font-size: 22rpx;
}

.record-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.status-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-pill.visited {
  color: #865300;
  background: rgba(255, 207, 92, 0.24);
}

.status-pill.planned {
  color: #0e5d66;
  background: rgba(93, 231, 242, 0.2);
}

.record-date {
  color: rgba(16, 53, 59, 0.48);
  font-size: 22rpx;
}

.record-text {
  display: block;
  margin-top: 18rpx;
  color: rgba(16, 53, 59, 0.78);
  font-size: 26rpx;
  line-height: 1.7;
}

.record-photo-grid {
  margin-top: 18rpx;
}

.record-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.record-action {
  font-size: 23rpx;
}

.record-action.muted {
  color: rgba(16, 53, 59, 0.5);
}

.record-action.danger {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #a73f36;
  background: rgba(188, 88, 77, 0.1);
}

.empty-state {
  padding: 34rpx 16rpx 24rpx;
  text-align: center;
}

.empty-title {
  display: block;
  color: #10353b;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-text {
  display: block;
  margin-top: 10rpx;
  color: rgba(16, 53, 59, 0.6);
  font-size: 24rpx;
  line-height: 1.7;
}
